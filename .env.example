# GitHub Packages auth — required to install @jasperlepardo/base-design-system
# A classic PAT with read:packages scope, or `gh auth token` locally.
GITHUB_TOKEN=

# Database (CPQ data model lives here)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tactik?schema=public"

# Web app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
